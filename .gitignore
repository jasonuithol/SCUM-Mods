# Scratch / working dir: SCUM-AllowMods bundle, build outputs, db_tier.exe,
# DB backups, the live.lua hot-reload buffer, recon output dumps.
.staging/

# Build artifacts (anywhere)
build/
dist/
*.spec
__pycache__/
*.pyc
*.exe

# Binaries / archives
*.pak
*.dll
*.zip

# GarbageGoober runtime state (generated on the server; the store is the source
# of truth there and must never be overwritten by a repo copy or committed).
Mods/GarbageGoober/entitlements.lua
Mods/GarbageGoober/GarbageGoober.log

# SCUM save data + DB backups
*.db
*.db-wal
*.db-shm
*.db-backup
*.bak
*.bak-*

# OS / editor cruft
Thumbs.db
desktop.ini
.DS_Store
