# Scratch / working dir: SCUM-AllowMods bundle, build outputs,
# DB backups, the live.lua hot-reload buffer, recon output dumps.
.staging/

# Build artifacts (anywhere)
build/
dist/
*.spec
__pycache__/
*.pyc
*.exe

# Python service (Services/MapPingService) — venv + secrets + local artifacts.
# NEVER commit .env (holds the Discord bot token) or the map image (copyrighted).
.venv/
.env
Services/MapPingService/scum_map.png
Services/MapPingService/ping_preview.png

# Binaries / archives
*.pak
*.dll
*.zip

# GarbageGoober runtime state (generated on the server; the store is the source
# of truth there and must never be overwritten by a repo copy or committed).
Mods/GarbageGoober/entitlements.lua
Mods/GarbageGoober/GarbageGoober.log
Mods/GarbageGoober/categories.cache.yaml
# FlagUpkeep runtime state (same rule: generated on the server, never committed)
Mods/FlagUpkeep/entitlements.lua
Mods/FlagUpkeep/FlagUpkeep.log

# SCUM save data + DB backups
*.db
*.db-wal
*.db-shm
*.db-backup
*.bak
*.bak-*

# OS / editor cruft
Thumbs.db
desktop.ini
.DS_Store
