# Copy to .env and fill in. Never commit the real .env.
DISCORD_BOT_TOKEN=your-bot-token-here
DISCORD_CHANNEL_ID=123456789012345678
# Optional but recommended during development for instant slash-command sync:
DISCORD_GUILD_ID=123456789012345678

# Shared secret between the UE4SS mod and this sidecar. Change it.
SIDECAR_API_KEY=change-me
HOST=127.0.0.1
PORT=8765
